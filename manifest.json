{
  "name": "Simple adblock",
  "manifest_version": 3,
  "version": "0.2",
  "description": "Hide elements from page",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "run_at": "document_end",
      "js": ["src/contentScript.js"]
    }
  ],
  "action": {
    "default_title": "Simple adblock",
    "default_icon": "icon.png",
    "default_popup": "src/popup.html"
  },
  "icons":{
    "128": "icon.png"
  }
}
