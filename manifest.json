{
  "name": "Simple adblock",
  "manifest_version": 3,
  "version": "1.0.1",
  "description": "Manual hiding elements from page",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "run_at": "document_end",
      "js": ["src/contentScript.js"]
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Simple adblock",
    "default_popup": "popup.html",
    "default_icon": {"96" : "images/popup_icon.png"}
  },
  "icons":{
    "96" : "images/store_icon96.png",
    "128" : "images/store_icon128.png"
  }
}